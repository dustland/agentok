
# Start the conversation (AG2 1.0 network)

async def _register_agent(hub, agent):
    """Register an Agent on the Hub and return its AgentClient."""
    return await hub.register(
        agent,
        Passport(name=agent.name),
        Resume(),
    )


async def _chat_result_from_channel(hub, channel_id, chat_id=None):
    """Build a Studio-compatible chat result dict from the channel WAL."""
    history = []
    try:
        wal = await hub.read_wal(channel_id)
        for envelope in wal:
            text = ""
            if getattr(envelope, "event_data", None):
                text = envelope.event_data.get("text") or ""
            if text:
                history.append({
                    "role": "assistant",
                    "name": getattr(envelope, "sender_id", "") or "agent",
                    "content": text,
                })
    except Exception as exc:
        history.append({"role": "system", "content": f"Failed to read WAL: {exc}"})

    summary = history[-1]["content"] if history else ""
    return {
        "chat_id": chat_id or channel_id,
        "chat_history": history,
        "summary": summary,
        "cost": {},
        "human_input": [],
    }


async def _run_pair_chat(opener, recipient, message, max_turns=None, timeout=300.0):
    """Run a 1:1 chat via consulting (1 turn) or round_robin workflow (N turns)."""
    if max_turns and int(max_turns) > 1:
        graph = TransitionGraph.round_robin(
            participants=[opener.agent_id, recipient.agent_id],
            max_turns=int(max_turns),
        )
        channel = await opener.open(
            type="workflow",
            target=recipient.agent_id,
            knobs={"graph": graph.to_dict()},
        )
    else:
        channel = await opener.open(
            type="consulting",
            target=recipient.agent_id,
        )
    await channel.send(message)
    await opener.wait_for_channel_event(
        channel_id=channel.channel_id,
        predicate=lambda e: e.event_type == EV_CHANNEL_CLOSED,
        timeout=timeout,
    )
    return channel


